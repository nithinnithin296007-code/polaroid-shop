# ── SERVER ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/your_db_name
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d
PORT=5000
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── PAYMENT PROVIDER ─────────────────────────────────────────────────────────
# Choose ONE provider and fill in only those credentials.
# Options: razorpay | stripe | cod
PAYMENT_PROVIDER=cod

# ── Razorpay (fill these if PAYMENT_PROVIDER=razorpay) ───────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Stripe (fill these if PAYMENT_PROVIDER=stripe) ───────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# ── COD / UPI via WhatsApp (fill these if PAYMENT_PROVIDER=cod) ──────────────
# Include country code, no '+': e.g. 919999999999 for India
COD_WHATSAPP_NUMBER=91XXXXXXXXXX
COD_UPI_ID=yourname@upi
